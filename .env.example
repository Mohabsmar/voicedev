# VoiceDev Environment Configuration
# Copy this file to .env and add your API keys

# Database (SQLite - works out of the box)
DATABASE_URL="file:./db/dev.db"

# LLM Providers (add the ones you want to use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
ZAI_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=
REPLICATE_API_TOKEN=
TOGETHER_API_KEY=
ELEVENLABS_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=

# Messaging Channels (optional)
TELEGRAM_BOT_TOKEN=
WHATSAPP_ACCESS_TOKEN=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
